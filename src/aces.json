{
	"$schema": "../SDK/plugin-sdk/v1/aces.schema.json",
	"media": {
		"conditions": [
			{
				"id": "on-state-changed",
				"scriptName": "OnStateChanged",
				"isTrigger": true
			},
			{
				"id": "on-error",
				"scriptName": "OnError",
				"isTrigger": true
			},
			{
				"id": "is-playing",
				"scriptName": "IsPlaying"
			},
			{
				"id": "is-paused",
				"scriptName": "IsPaused"
			},
			{
				"id": "is-ended",
				"scriptName": "IsEnded"
			},
			{
				"id": "is-muted",
				"scriptName": "IsMuted"
			},
			{
				"id": "is-loading",
				"scriptName": "IsLoading"
			},
			{
				"id": "is-ready",
				"scriptName": "IsReady"
			},
			{
				"id": "is-offline",
				"scriptName": "IsOffline"
			},
			{
				"id": "has-subtitles",
				"scriptName": "HasSubtitles"
			},
			{
				"id": "has-subtitle-language",
				"scriptName": "HasSubtitleLanguage",
				"params": [
					{
						"id": "lang",
						"type": "string"
					}
				]
			},
			{
				"id": "has-subtitle-label",
				"scriptName": "HasSubtitleLabel",
				"params": [
					{
						"id": "label",
						"type": "string"
					}
				]
			},
			{
				"id": "on-subtitles-available",
				"scriptName": "OnSubtitlesAvailable",
				"isTrigger": true
			}
		],
		"actions": [
			{
				"id": "play",
				"scriptName": "Play"
			},
			{
				"id": "pause",
				"scriptName": "Pause"
			},
			{
				"id": "set-muted",
				"scriptName": "SetMuted",
				"params": [
					{
						"id": "mute",
						"type": "boolean"
					}
				]
			},
			{
				"id": "set-playback-time",
				"scriptName": "SetPlaybackTime",
				"params": [
					{
						"id": "playback-time",
						"type": "number"
					}
				]
			},
			{
				"id": "set-volume",
				"scriptName": "SetVolume",
				"params": [
					{
						"id": "level",
						"type": "number"
					}
				]
			},
			{
				"id": "set-url",
				"scriptName": "SetURL",
				"params": [
					{
						"id": "url",
						"type": "string"
					}
				]
			},
			{
				"id": "set-subtitles",
				"scriptName": "SetSubtitles",
				"params": [
					{
						"id": "language",
						"type": "string"
					}
				]
			},
			{
				"id": "set-enable-chrome",
				"scriptName": "SetEnableChrome",
				"params": [
					{
						"id": "enable",
						"type": "boolean"
					}
				]
			},
			{
				"id": "add-subtitle-source",
				"scriptName": "AddSubtitleSource",
				"params": [
					{
						"id": "url",
						"type": "string"
					},
					{
						"id": "language",
						"type": "string"
					},
					{
						"id": "label",
						"type": "string"
					}
				]
			},
			{
				"id": "add-project-subtitle-source",
				"scriptName": "AddProjectSubtitleSource",
				"isAsync": true,
				"params": [
					{
						"id": "file",
						"type": "projectfile"
					},
					{
						"id": "language",
						"type": "string"
					},
					{
						"id": "label",
						"type": "string"
					}
				]
			},
			{
				"id": "resize",
				"scriptName": "Resize"
			}
		],
		"expressions": [
			{
				"id": "state",
				"expressionName": "State",
				"returnType": "string"
			},
			{
				"id": "get-last-error-message",
				"expressionName": "GetLastErrorMessage",
				"returnType": "string"
			},
			{
				"id": "get-last-error-category",
				"expressionName": "GetLastErrorCategory",
				"returnType": "string"
			},
			{
				"id": "get-current-playback-time",
				"expressionName": "GetCurrentPlaybackTime",
				"returnType": "number"
			},
			{
				"id": "get-current-volume",
				"expressionName": "GetCurrentVolume",
				"returnType": "number"
			},
			{
				"id": "get-duration",
				"expressionName": "GetDuration",
				"returnType": "number"
			},
			{
				"id": "url",
				"expressionName": "URL",
				"returnType": "string"
			},
			{
				"id": "subtitles",
				"expressionName": "Subtitles",
				"returnType": "string"
			},
			{
				"id": "get-enable-chrome",
				"expressionName": "GetEnableChrome",
				"returnType": "number"
			},
			{
				"id": "get-subtitle-count",
				"expressionName": "GetSubtitleCount",
				"returnType": "number"
			},
			{
				"id": "get-subtitle-language-at",
				"expressionName": "GetSubtitleLanguageAt",
				"returnType": "string",
				"params": [
					{
						"id": "index",
						"type": "number"
					}
				]
			},
			{
				"id": "get-subtitle-label-at",
				"expressionName": "GetSubtitleLabelAt",
				"returnType": "string",
				"params": [
					{
						"id": "index",
						"type": "number"
					}
				]
			}
		]
	}
}