{
	"$schema": "../SDK/plugin-sdk/v1/aces.schema.json",
	"media": {
		"conditions": [
			{
				"id": "on-state-changed",
				"scriptName": "OnStateChanged",
				"isTrigger": true
			},
			{
				"id": "on-error",
				"scriptName": "OnError",
				"isTrigger": true
			},
			{
				"id": "is-playing",
				"scriptName": "IsPlaying"
			},
			{
				"id": "is-paused",
				"scriptName": "IsPaused"
			},
			{
				"id": "is-ended",
				"scriptName": "IsEnded"
			},
			{
				"id": "is-muted",
				"scriptName": "IsMuted"
			},
			{
				"id": "is-loading",
				"scriptName": "IsLoading"
			},
			{
				"id": "is-ready",
				"scriptName": "IsReady"
			},
			{
				"id": "is-offline",
				"scriptName": "IsOffline"
			}
		],
		"actions": [
			{
				"id": "play",
				"scriptName": "Play"
			},
			{
				"id": "pause",
				"scriptName": "Pause"
			},
			{
				"id": "set-muted",
				"scriptName": "SetMuted",
				"params": [
					{
						"id": "mute",
						"type": "boolean"
					}
				]
			},
			{
				"id": "set-playback-time",
				"scriptName": "SetPlaybackTime",
				"params": [
					{
						"id": "playback-time",
						"type": "number"
					}
				]
			},
			{
				"id": "set-volume",
				"scriptName": "SetVolume",
				"params": [
					{
						"id": "level",
						"type": "number"
					}
				]
			},
			{
				"id": "set-url",
				"scriptName": "SetURL",
				"isAsync": true,
				"params": [
					{
						"id": "url",
						"type": "string"
					}
				]
			},
			{
				"id": "set-subtitles",
				"scriptName": "SetSubtitles",
				"params": [
					{
						"id": "language",
						"type": "string"
					}
				]
			},
			{
				"id": "set-enable-chrome",
				"scriptName": "SetEnableChrome",
				"params": [
					{
						"id": "enable",
						"type": "boolean"
					}
				]
			},
			{
				"id": "resize",
				"scriptName": "Resize"
			},
			{
				"id": "set-playback-rate",
				"scriptName": "SetPlaybackRate",
				"params": [
					{
						"id": "rate",
						"type": "number"
					}
				]
			}
		],
		"expressions": [
			{
				"id": "state",
				"expressionName": "State",
				"returnType": "string"
			},
			{
				"id": "get-last-error-message",
				"expressionName": "GetLastErrorMessage",
				"returnType": "string"
			},
			{
				"id": "get-last-error-category",
				"expressionName": "GetLastErrorCategory",
				"returnType": "string"
			},
			{
				"id": "get-current-playback-time",
				"expressionName": "GetCurrentPlaybackTime",
				"returnType": "number"
			},
			{
				"id": "get-current-volume",
				"expressionName": "GetCurrentVolume",
				"returnType": "number"
			},
			{
				"id": "get-duration",
				"expressionName": "GetDuration",
				"returnType": "number"
			},
			{
				"id": "url",
				"expressionName": "URL",
				"returnType": "string"
			},
			{
				"id": "subtitles",
				"expressionName": "Subtitles",
				"returnType": "string"
			},
			{
				"id": "get-enable-chrome",
				"expressionName": "GetEnableChrome",
				"returnType": "number"
			},
			{
				"id": "get-playback-rate",
				"expressionName": "GetPlaybackRate",
				"returnType": "number"
			},
			{
				"id": "get-available-playback-rate",
				"expressionName": "GetAvailablePlaybackRate",
				"returnType": "number",
				"params": [
					{
						"id": "index",
						"type": "number"
					}
				]
			},
			{
				"id": "get-available-playback-rate-count",
				"expressionName": "GetAvailablePlaybackRateCount",
				"returnType": "number"
			},
			{
				"id": "get-video-title",
				"expressionName": "GetVideoTitle",
				"returnType": "string"
			},
			{
				"id": "get-player-url",
				"expressionName": "GetPlayerUrl",
				"returnType": "string"
			},
			{
				"id": "get-video-loaded-fraction",
				"expressionName": "GetVideoLoadedFraction",
				"returnType": "number"
			}
		]
	}
}
